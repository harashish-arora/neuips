\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces \textbf  {Top-12 features per featurizer (LightGBM, eval).} Bars are the global mean(|SHAP|) on \ensuremath  {\qopname  \relax o{log}_{10} S}\xspace  {}; colour encodes the block (blue\tmspace  +\thinmuskip {.1667em}$=$\tmspace  +\thinmuskip {.1667em}solute, green\tmspace  +\thinmuskip {.1667em}$=$\tmspace  +\thinmuskip {.1667em}solvent, red\tmspace  +\thinmuskip {.1667em}$=$\tmspace  +\thinmuskip {.1667em}temperature). On all three descriptor representations the top features are exactly the axes of the General Solubility Equation: a polar surface area term (\texttt  {TPSA} / \texttt  {TopoPSA(NO)}), a complexity term (\texttt  {BertzCT}), a logP term (\texttt  {MolLogP}), a solvent polarity proxy (\texttt  {MaxPartialCharge}), and a temperature term (\texttt  {T\_norm}). Abraham-only correctly recovers the canonical LSER ranking $E > S \approx B \approx A > V$ on the solute side.\relax }}{26}{figure.caption.86}\protected@file@percent }
\newlabel{fig:interp_global_top}{{19}{26}{\textbf {Top-12 features per featurizer (LightGBM, eval).} Bars are the global mean(|SHAP|) on \logS {}; colour encodes the block (blue\,$=$\,solute, green\,$=$\,solvent, red\,$=$\,temperature). On all three descriptor representations the top features are exactly the axes of the General Solubility Equation: a polar surface area term (\texttt {TPSA} / \texttt {TopoPSA(NO)}), a complexity term (\texttt {BertzCT}), a logP term (\texttt {MolLogP}), a solvent polarity proxy (\texttt {MaxPartialCharge}), and a temperature term (\texttt {T\_norm}). Abraham-only correctly recovers the canonical LSER ranking $E > S \approx B \approx A > V$ on the solute side.\relax }{figure.caption.86}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {11.2}Top global features and the General Solubility Equation}{26}{subsection.11.2}\protected@file@percent }
\newlabel{sec:interp_global}{{11.2}{26}{Top global features and the General Solubility Equation}{subsection.11.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {20}{\ignorespaces \textbf  {Signed SHAP directionality.} Bar length is the usual global mean(|SHAP|), so the ranking is unchanged from Figure\nobreakspace  {}\ref  {fig:interp_global_top}. Bar colour and the printed Spearman \(\rho \) show direction: blue features have high values that lower predicted \ensuremath  {\qopname  \relax o{log}_{10} S}\xspace  {}, red features have high values that raise predicted \ensuremath  {\qopname  \relax o{log}_{10} S}\xspace  {}. The descriptor panel says the strongest solute features -- \texttt  {TPSA}, \texttt  {BertzCT}, \texttt  {MolWt}, \texttt  {RingCount}, heteroatom counts -- mostly push predictions down when large, while temperature and solvent partial-charge features push predictions up. The Abraham-only panel makes the LSER story explicit: solute \(E,S,B,A\) lower predicted solubility when large, whereas increasing temperature raises it.\relax }}{27}{figure.caption.87}\protected@file@percent }
\newlabel{fig:interp_signed_shap}{{20}{27}{\textbf {Signed SHAP directionality.} Bar length is the usual global mean(|SHAP|), so the ranking is unchanged from Figure~\ref {fig:interp_global_top}. Bar colour and the printed Spearman \(\rho \) show direction: blue features have high values that lower predicted \logS {}, red features have high values that raise predicted \logS {}. The descriptor panel says the strongest solute features -- \texttt {TPSA}, \texttt {BertzCT}, \texttt {MolWt}, \texttt {RingCount}, heteroatom counts -- mostly push predictions down when large, while temperature and solvent partial-charge features push predictions up. The Abraham-only panel makes the LSER story explicit: solute \(E,S,B,A\) lower predicted solubility when large, whereas increasing temperature raises it.\relax }{figure.caption.87}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {11.3}Per-solvent profiles}{27}{subsection.11.3}\protected@file@percent }
\newlabel{sec:interp_per_solvent}{{11.3}{27}{Per-solvent profiles}{subsection.11.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {21}{\ignorespaces \textbf  {Per-solvent SHAP profile (Dissolvr, eval).} Rows are the top-15 globally-important features (descending); columns are the 25 \texttt  {eval} solvents, ordered by hierarchical clustering on the column vectors. Cells are column-normalised mean(|SHAP|), so darker \(=\) less important relative to the rest of that solvent's profile. Two qualitative patterns are visible: (i) for typical organic solvents the model relies on \texttt  {TPSA} and \texttt  {BertzCT} of the \emph  {solute}; (ii) for the extreme solvents (water, n-hexane, cyclohexane) it switches to \texttt  {MaxPartialCharge} and \texttt  {MaxAbsEStateIndex} of the \emph  {solvent}. A third specialised pattern shows up for DMF and THF, where \texttt  {PEOE\_VSA8} of the solvent dominates.\relax }}{28}{figure.caption.88}\protected@file@percent }
\newlabel{fig:interp_per_solvent_heatmap}{{21}{28}{\textbf {Per-solvent SHAP profile (Dissolvr, eval).} Rows are the top-15 globally-important features (descending); columns are the 25 \texttt {eval} solvents, ordered by hierarchical clustering on the column vectors. Cells are column-normalised mean(|SHAP|), so darker \(=\) less important relative to the rest of that solvent's profile. Two qualitative patterns are visible: (i) for typical organic solvents the model relies on \texttt {TPSA} and \texttt {BertzCT} of the \emph {solute}; (ii) for the extreme solvents (water, n-hexane, cyclohexane) it switches to \texttt {MaxPartialCharge} and \texttt {MaxAbsEStateIndex} of the \emph {solvent}. A third specialised pattern shows up for DMF and THF, where \texttt {PEOE\_VSA8} of the solvent dominates.\relax }{figure.caption.88}{}}
\@writefile{lot}{\contentsline {table}{\numberline {17}{\ignorespaces Per-solvent top-3 SHAP features (RDKit, eval). ``solv'' prefix denotes solvent-side features; otherwise the feature is on the solute. N is the number of \texttt  {eval} rows for that solvent.\relax }}{28}{table.caption.89}\protected@file@percent }
\newlabel{tab:interp_anchor_solvents}{{17}{28}{Per-solvent top-3 SHAP features (RDKit, eval). ``solv'' prefix denotes solvent-side features; otherwise the feature is on the solute. N is the number of \texttt {eval} rows for that solvent.\relax }{table.caption.89}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {11.4}Solvents the model treats similarly}{28}{subsection.11.4}\protected@file@percent }
\newlabel{sec:interp_clustering}{{11.4}{28}{Solvents the model treats similarly}{subsection.11.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {22}{\ignorespaces \textbf  {Solvent map under the Abraham-only featurizer.} Each point is one of the 25 \texttt  {eval} solvents at its 2-D MDS coordinates derived from the per-solvent SHAP fingerprint distance \(1 - \qopname  \relax o{cos}(\cdot )\). \textbf  {Marker shape} encodes the chemist's classical Snyder family (\(\star \)\nobreakspace  {}water, \(\blacksquare \)\nobreakspace  {}apolar alkane, \(\blacktriangle \)\nobreakspace  {}aprotic, \(\bullet \)\nobreakspace  {}protic alcohol). \textbf  {Marker colour} encodes the model's automatic cluster (K=4 average-linkage hierarchical, on the same distance). Same colour \(=\) the model treats those solvents the same way; same shape \(=\) chemists treat them the same way. Disagreements -- such as the model placing water in the same purple cluster as DMF / chloroform / toluene -- are visually obvious. ARI vs the chemist labelling \(=\) \leavevmode {\color  {blue!70!black}0.21}.\relax }}{29}{figure.caption.90}\protected@file@percent }
\newlabel{fig:interp_solvent_map}{{22}{29}{\textbf {Solvent map under the Abraham-only featurizer.} Each point is one of the 25 \texttt {eval} solvents at its 2-D MDS coordinates derived from the per-solvent SHAP fingerprint distance \(1 - \cos (\cdot )\). \textbf {Marker shape} encodes the chemist's classical Snyder family (\(\star \)~water, \(\blacksquare \)~apolar alkane, \(\blacktriangle \)~aprotic, \(\bullet \)~protic alcohol). \textbf {Marker colour} encodes the model's automatic cluster (K=4 average-linkage hierarchical, on the same distance). Same colour \(=\) the model treats those solvents the same way; same shape \(=\) chemists treat them the same way. Disagreements -- such as the model placing water in the same purple cluster as DMF / chloroform / toluene -- are visually obvious. ARI vs the chemist labelling \(=\) \numval {0.21}.\relax }{figure.caption.90}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {23}{\ignorespaces \textbf  {Solvent maps across four featurizers.} Same MDS-on-SHAP construction as Figure\nobreakspace  {}\ref  {fig:interp_solvent_map} but with one panel per featurizer. Top row (\textit  {descriptor / Abraham}) cleanly separates water, alkanes, the aprotic-aromatic group (DMF / THF / chloroform / toluene), and a large alcohol-and-ester cluster. Bottom row (\textit  {circular fingerprints}) is structurally driven -- it isolates DMF and cyclohexane as singletons, places n-hexane next to long-chain alcohols, and dumps everything else into one mass -- a chemistry-blind grouping. ARI scores quantify the agreement gap (\leavevmode {\color  {blue!70!black}0.21}--\leavevmode {\color  {blue!70!black}0.23} for descriptors vs.\ \leavevmode {\color  {blue!70!black}0.15} for fingerprints).\relax }}{30}{figure.caption.91}\protected@file@percent }
\newlabel{fig:interp_dendrograms}{{23}{30}{\textbf {Solvent maps across four featurizers.} Same MDS-on-SHAP construction as Figure~\ref {fig:interp_solvent_map} but with one panel per featurizer. Top row (\textit {descriptor / Abraham}) cleanly separates water, alkanes, the aprotic-aromatic group (DMF / THF / chloroform / toluene), and a large alcohol-and-ester cluster. Bottom row (\textit {circular fingerprints}) is structurally driven -- it isolates DMF and cyclohexane as singletons, places n-hexane next to long-chain alcohols, and dumps everything else into one mass -- a chemistry-blind grouping. ARI scores quantify the agreement gap (\numval {0.21}--\numval {0.23} for descriptors vs.\ \numval {0.15} for fingerprints).\relax }{figure.caption.91}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {11.5}Abraham/LSER axes per solvent}{30}{subsection.11.5}\protected@file@percent }
\newlabel{sec:interp_abraham}{{11.5}{30}{Abraham/LSER axes per solvent}{subsection.11.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {11.6}Pairwise interactions}{30}{subsection.11.6}\protected@file@percent }
\newlabel{sec:interp_interactions}{{11.6}{30}{Pairwise interactions}{subsection.11.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {24}{\ignorespaces \textbf  {Abraham/LSER axis importance per solvent.} Rows are solvents grouped (top-bottom) into apolar, aprotic-aromatic \(+\)\nobreakspace  {}ester\nobreakspace  {}/\nobreakspace  {}ketone, protic alcohols, and water. Columns are the six Abraham/LSER axes. Cells are mean(|SHAP|) for that (side, solvent, axis) cell on \texttt  {eval}. The panel reads as a literal LSER table: alkanes have very large $B$ and $S$ on the solvent side (the model uses the absence of those features to identify the medium), water has a large solvent-side $E$ \emph  {and} the largest solute-side $E$ in the dataset, and DMF/toluene foreground solvent-side $B$.\relax }}{31}{figure.caption.92}\protected@file@percent }
\newlabel{fig:interp_abraham}{{24}{31}{\textbf {Abraham/LSER axis importance per solvent.} Rows are solvents grouped (top-bottom) into apolar, aprotic-aromatic \(+\)~ester~/~ketone, protic alcohols, and water. Columns are the six Abraham/LSER axes. Cells are mean(|SHAP|) for that (side, solvent, axis) cell on \texttt {eval}. The panel reads as a literal LSER table: alkanes have very large $B$ and $S$ on the solvent side (the model uses the absence of those features to identify the medium), water has a large solvent-side $E$ \emph {and} the largest solute-side $E$ in the dataset, and DMF/toluene foreground solvent-side $B$.\relax }{figure.caption.92}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {11.7}Graph-based interpretation: GCN}{31}{subsection.11.7}\protected@file@percent }
\newlabel{sec:interp_gcn}{{11.7}{31}{Graph-based interpretation: GCN}{subsection.11.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {25}{\ignorespaces \textbf  {Top SHAP interaction features.} Bars are mean(|$\Phi _{ij}$|) on \texttt  {eval}; colour encodes the block-pair (solute$\times $solute, solute$\times $solvent, etc.). On Abraham-only, the top-8 pairs are exclusively within the solute LSER axes (textbook within-molecule solvation coupling); cross-block solute$\times $solvent pairs appear from rank 9 onward and are matched-axis ($E\tmspace  -\thinmuskip {.1667em}\times \tmspace  -\thinmuskip {.1667em}E$, $A\tmspace  -\thinmuskip {.1667em}\times \tmspace  -\thinmuskip {.1667em}A$, $E\tmspace  -\thinmuskip {.1667em}\times \tmspace  -\thinmuskip {.1667em}B$) -- the off-diagonal LSER cross-terms. On RDKit, the top-4 pairs are within the GSE axes (\texttt  {BertzCT}\(\times \)\texttt  {MolLogP}, etc.); the largest cross-block interaction is \texttt  {BertzCT(solute)}\(\times \) \texttt  {MaxPartialCharge(solv)}, the discrete analogue of a partition coefficient term.\relax }}{32}{figure.caption.93}\protected@file@percent }
\newlabel{fig:interp_interactions}{{25}{32}{\textbf {Top SHAP interaction features.} Bars are mean(|$\Phi _{ij}$|) on \texttt {eval}; colour encodes the block-pair (solute$\times $solute, solute$\times $solvent, etc.). On Abraham-only, the top-8 pairs are exclusively within the solute LSER axes (textbook within-molecule solvation coupling); cross-block solute$\times $solvent pairs appear from rank 9 onward and are matched-axis ($E\!\times \!E$, $A\!\times \!A$, $E\!\times \!B$) -- the off-diagonal LSER cross-terms. On RDKit, the top-4 pairs are within the GSE axes (\texttt {BertzCT}\(\times \)\texttt {MolLogP}, etc.); the largest cross-block interaction is \texttt {BertzCT(solute)}\(\times \) \texttt {MaxPartialCharge(solv)}, the discrete analogue of a partition coefficient term.\relax }{figure.caption.93}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {26}{\ignorespaces \textbf  {GCN dual-encoder interpretability.} (a) Mean \(|\Delta \tmspace  +\thinmuskip {.1667em}\ensuremath  {\qopname  \relax o{log}_{10} S}\xspace  |\) per atom-occlusion, broken down by RDKit atom ``kind'' (element \(\times \) aromaticity \(\times \) ring membership) on the eval-split sample; error bars are \(\sigma /\sqrt  {n}\). Heavy heteroatoms (S, P, N) dominate; aromatic carbon and aliphatic ring-carbon are essentially equivalent. (b) Total \(\DOTSB \sum@ \slimits@ |\Delta \tmspace  +\thinmuskip {.1667em}\ensuremath  {\qopname  \relax o{log}_{10} S}\xspace  |\) per BRICS substructure, for fragments that appear at least 30 times in the sample. Every top fragment is a chemistry-textbook solubility motif; no opaque substructure makes the top 15.\relax }}{33}{figure.caption.94}\protected@file@percent }
\newlabel{fig:interp_gcn}{{26}{33}{\textbf {GCN dual-encoder interpretability.} (a) Mean \(|\Delta \,\logS |\) per atom-occlusion, broken down by RDKit atom ``kind'' (element \(\times \) aromaticity \(\times \) ring membership) on the eval-split sample; error bars are \(\sigma /\sqrt {n}\). Heavy heteroatoms (S, P, N) dominate; aromatic carbon and aliphatic ring-carbon are essentially equivalent. (b) Total \(\sum |\Delta \,\logS |\) per BRICS substructure, for fragments that appear at least 30 times in the sample. Every top fragment is a chemistry-textbook solubility motif; no opaque substructure makes the top 15.\relax }{figure.caption.94}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {11.8}What the interpretability says}{33}{subsection.11.8}\protected@file@percent }
\newlabel{sec:interp_summary}{{11.8}{33}{What the interpretability says}{subsection.11.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {27}{\ignorespaces \textbf  {Example GCN graph attributions.} Four solutes were chosen from the \texttt  {eval} split to expose the motifs that dominate the aggregate BRICS ranking: sulfur/sulfone, carboxylic acid / nitro-aromatic, phenol/aromatic OH, and piperazine/diamine. The underlying attribution is signed atom occlusion: red regions increase the predicted \ensuremath  {\qopname  \relax o{log}_{10} S}\xspace  {} relative to the same graph with that atom's features zeroed; blue regions decrease it. The maps are qualitative but coherent: acidic, nitro, sulfone, and amide-like atoms are high-leverage; aromatic scaffolds often provide broad negative fields; and heteroatom-rich fragments such as piperazine or carboxylate dominate local prediction changes.\relax }}{34}{figure.caption.95}\protected@file@percent }
\newlabel{fig:interp_gcn_examples}{{27}{34}{\textbf {Example GCN graph attributions.} Four solutes were chosen from the \texttt {eval} split to expose the motifs that dominate the aggregate BRICS ranking: sulfur/sulfone, carboxylic acid / nitro-aromatic, phenol/aromatic OH, and piperazine/diamine. The underlying attribution is signed atom occlusion: red regions increase the predicted \logS {} relative to the same graph with that atom's features zeroed; blue regions decrease it. The maps are qualitative but coherent: acidic, nitro, sulfone, and amide-like atoms are high-leverage; aromatic scaffolds often provide broad negative fields; and heteroatom-rich fragments such as piperazine or carboxylate dominate local prediction changes.\relax }{figure.caption.95}{}}
\@writefile{toc}{\contentsline {paragraph}{Caveats.}{34}{section*.96}\protected@file@percent }
