\@writefile{lot}{\contentsline {table}{\numberline {13}{\ignorespaces Power-law fits $\mathrm  {RMSE}(N) = a \cdot N^{-b} + c$ per (model, evaluation split), plus the train-side fit (only available for the deep models; LightGBM does not save a per-fraction train-RMSE diagnostic). $b$ is the scaling exponent (larger = more bang per data row). $c$ is the model's irreducible asymptote (smaller = better in the limit of infinite data). $R^{2}$ is the coefficient of determination of the fit on the seven $(N, \mathrm  {RMSE})$ points. The asymptote $c$ is the column to read for Q4: it is the model's best achievable RMSE on this split, given infinite data and the same representation.\relax }}{19}{table.caption.59}\protected@file@percent }
\newlabel{tab:scaling_fits}{{13}{19}{Power-law fits $\mathrm {RMSE}(N) = a \cdot N^{-b} + c$ per (model, evaluation split), plus the train-side fit (only available for the deep models; LightGBM does not save a per-fraction train-RMSE diagnostic). $b$ is the scaling exponent (larger = more bang per data row). $c$ is the model's irreducible asymptote (smaller = better in the limit of infinite data). $R^{2}$ is the coefficient of determination of the fit on the seven $(N, \mathrm {RMSE})$ points. The asymptote $c$ is the column to read for Q4: it is the model's best achievable RMSE on this split, given infinite data and the same representation.\relax }{table.caption.59}{}}
\@writefile{lot}{\contentsline {table}{\numberline {14}{\ignorespaces Q4 extrapolation table. For every (model, evaluation split) pair we report the asymptote $c$ from Table\nobreakspace  {}\ref  {tab:scaling_fits}, the per-split aleatoric floor $\ensuremath  {\varepsilon _{\text  {aleatoric}}}\xspace  $ from Table\nobreakspace  {}\ref  {tab:scaling_floors}, the gap $\Delta = c - \ensuremath  {\varepsilon _{\text  {aleatoric}}}\xspace  $, the training-set size $N^{\star }_{95}$ at which RMSE comes within $5\%$ of the model's own asymptote (a moderate, achievable target), and the size $N^{\star }_{\ensuremath  {\varepsilon _{\text  {aleatoric}}}\xspace  }$ that would bring RMSE to within $0.05$ logS of the aleatoric floor (Eq.\nobreakspace  {}\ref  {eq:nstar}). Entries marked $\infty $ have $c \geq \ensuremath  {\varepsilon _{\text  {aleatoric}}}\xspace  + 0.05$, so no finite $N$ meets the target within the saturating power-law model. All $N^{\star }_{\ensuremath  {\varepsilon _{\text  {aleatoric}}}\xspace  }$ are $\infty $ -- the central Q4 finding.\relax }}{19}{table.caption.60}\protected@file@percent }
\newlabel{tab:scaling_extrapolation}{{14}{19}{Q4 extrapolation table. For every (model, evaluation split) pair we report the asymptote $c$ from Table~\ref {tab:scaling_fits}, the per-split aleatoric floor $\epsA $ from Table~\ref {tab:scaling_floors}, the gap $\Delta = c - \epsA $, the training-set size $N^{\star }_{95}$ at which RMSE comes within $5\%$ of the model's own asymptote (a moderate, achievable target), and the size $N^{\star }_{\epsA }$ that would bring RMSE to within $0.05$ logS of the aleatoric floor (Eq.~\ref {eq:nstar}). Entries marked $\infty $ have $c \geq \epsA + 0.05$, so no finite $N$ meets the target within the saturating power-law model. All $N^{\star }_{\epsA }$ are $\infty $ -- the central Q4 finding.\relax }{table.caption.60}{}}
