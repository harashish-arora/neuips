\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces \textbf  {Multi-T vs.\ 298 K-locked, side-by-side.} Same $5$-seed runs as Tables\nobreakspace  {}\ref  {tab:transfer_multiT} and \ref  {tab:transfer_interp}. Top row: scratch. Bottom row: \textsc  {qm}. At $100$\% SC\textsuperscript  {3}\xspace  {}-train, the single-T \texttt  {sc3\_gold} \textsc  {rmse}\xspace  {} is roughly half the multi-T value, with QM-pretraining and scratch converging --- the residual error budget at room temperature is dominated by aleatoric noise rather than missing chemistry signal. (The \textsc  {filter} curves shown in the figure are an alternative single-T construction that keeps only real measurements with $T \tmspace  -\thinmuskip {.1667em} \in \tmspace  -\thinmuskip {.1667em} [\leavevmode {\color  {blue!70!black}295.15}, \leavevmode {\color  {blue!70!black}301.15}]$\nobreakspace  {}K; we use the Apelblat-evaluated variant in the main text because its larger training set avoids overfitting.)\relax }}{24}{figure.caption.80}\protected@file@percent }
\newlabel{fig:transfer_compare_T}{{17}{24}{\textbf {Multi-T vs.\ 298 K-locked, side-by-side.} Same $5$-seed runs as Tables~\ref {tab:transfer_multiT} and \ref {tab:transfer_interp}. Top row: scratch. Bottom row: \textsc {qm}. At $100$\% \scthree {}-train, the single-T \texttt {sc3\_gold} \RMSE {} is roughly half the multi-T value, with QM-pretraining and scratch converging --- the residual error budget at room temperature is dominated by aleatoric noise rather than missing chemistry signal. (The \textsc {filter} curves shown in the figure are an alternative single-T construction that keeps only real measurements with $T \! \in \! [\numval {295.15}, \numval {301.15}]$~K; we use the Apelblat-evaluated variant in the main text because its larger training set avoids overfitting.)\relax }{figure.caption.80}{}}
