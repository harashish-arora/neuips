\@writefile{lot}{\contentsline {table}{\numberline {12}{\ignorespaces Per-split aleatoric RMSE floors $\ensuremath  {\varepsilon _{\text  {aleatoric}}}\xspace  $ from Eq.\nobreakspace  {}\ref  {eq:eps_split}, computed on duplicate $(\text  {solute}, \text  {solvent}, \mathrm  {round}(T,0))$ triples within each split. $n_{\text  {trip}}$ is the number of duplicate triples; $n_{\text  {obs}}$ is the total number of observations participating in those triples (each contributes one residual against its group mean). Median per-triple std and the $90$th percentile capture the shape of the within-triple disagreement distribution: medians are sub-millimolar everywhere, and the heavy right tail is what drives $\ensuremath  {\varepsilon _{\text  {aleatoric}}}\xspace  $ above the median. $\ensuremath  {\varepsilon _{\text  {aleatoric}}}\xspace  $ is RMSE-comparable to the model RMSE reported on the same split.\relax }}{18}{table.caption.58}\protected@file@percent }
\newlabel{tab:scaling_floors}{{12}{18}{Per-split aleatoric RMSE floors $\epsA $ from Eq.~\ref {eq:eps_split}, computed on duplicate $(\text {solute}, \text {solvent}, \mathrm {round}(T,0))$ triples within each split. $n_{\text {trip}}$ is the number of duplicate triples; $n_{\text {obs}}$ is the total number of observations participating in those triples (each contributes one residual against its group mean). Median per-triple std and the $90$th percentile capture the shape of the within-triple disagreement distribution: medians are sub-millimolar everywhere, and the heavy right tail is what drives $\epsA $ above the median. $\epsA $ is RMSE-comparable to the model RMSE reported on the same split.\relax }{table.caption.58}{}}
